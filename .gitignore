# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml

# Virtual environments
.venv/
venv/
env/
ENV/

# Build artifacts
dist/
build/
*.egg-info/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Secrets and local env
.env
.env.*
*.pem
*.key
secrets.*

# Logs and temp outputs
*.log
tmp/
temp/
outputs/live_excel_master/*
!outputs/live_excel_master/.gitkeep

# Context backups local data
.context-backups/*
!.context-backups/.gitkeep

# Samples policy:
# data/samples may contain controlled examples that can be versioned.
# Real/sensitive samples must not be added to git; keep them local and untracked.
# Use .git/info/exclude or local ignore rules for sensitive sample files.
data/samples/*
!data/samples/.gitkeep
# Raw data policy:
# Keep folder structure in git, but ignore real imported files by default.
# Unignore placeholder file.
data/raw/*
!data/raw/.gitkeep

# Archived originals (real budget files, never commit)
data/archived_budgets/*
!data/archived_budgets/.gitkeep

# Processed/export artifacts (generated)
data/processed/*
!data/processed/.gitkeep
data/exports/*
!data/exports/.gitkeep

# Master may contain controlled templates only.
# Keep empty structure, ignore generated working files.
data/master/*
!data/master/.gitkeep

# Logs generated by import/validation runs
logs/imports/*
!logs/imports/.gitkeep
logs/validation/*
!logs/validation/.gitkeep

# Reports generated during analysis
reports/*
!reports/.gitkeep
!reports/sample_inspections/
reports/sample_inspections/*
!reports/sample_inspections/.gitkeep
!reports/bc3_diagnostics/
reports/bc3_diagnostics/*
!reports/bc3_diagnostics/.gitkeep
!reports/bc3_preliminary_parse/
reports/bc3_preliminary_parse/*
!reports/bc3_preliminary_parse/.gitkeep
!reports/bc3_intermediate_validation/
reports/bc3_intermediate_validation/*
!reports/bc3_intermediate_validation/.gitkeep


# Local test scratch
.tmp_tests/

# strict parser reports
!reports/bc3_strict_parse/
reports/bc3_strict_parse/*
!reports/bc3_strict_parse/.gitkeep
# strict validation reports
!reports/bc3_strict_validation/
reports/bc3_strict_validation/*
!reports/bc3_strict_validation/.gitkeep
# intermediate normalization reports
!reports/bc3_intermediate_normalization/
reports/bc3_intermediate_normalization/*
!reports/bc3_intermediate_normalization/.gitkeep
# intermediate normalization validation reports
!reports/bc3_intermediate_normalization_validation/
reports/bc3_intermediate_normalization_validation/*
!reports/bc3_intermediate_normalization_validation/.gitkeep
!reports/excel_full_reader/
reports/excel_full_reader/*
!reports/excel_full_reader/.gitkeep
!reports/excel_full_reader_validation/
reports/excel_full_reader_validation/*
!reports/excel_full_reader_validation/.gitkeep
!reports/excel_intermediate_normalization/
reports/excel_intermediate_normalization/*
!reports/excel_intermediate_normalization/.gitkeep
!reports/presto_diagnostics/
reports/presto_diagnostics/*
!reports/presto_diagnostics/.gitkeep
